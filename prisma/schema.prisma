generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // null for OAuth-only users
  accounts      Account[]
  sessions      Session[]
  fitnessPlans  FitnessPlan[]
  workoutSessions WorkoutSession[]
  bodyMeasurements BodyMeasurement[]
  favorites       Favorite[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model FitnessPlan {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile     Json             // Stores the UserProfile fields
  plan        Json             // Stores the generated FitnessPlan contents
  status      String           @default("ACTIVE") // ACTIVE, ARCHIVED
  version     Int              @default(1)
  workoutType String           @default("HOME") // HOME, GYM
  sessions    WorkoutSession[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model WorkoutSession {
  id                   String           @id @default(cuid())
  userId               String
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  fitnessPlanId        String?
  fitnessPlan          FitnessPlan?     @relation(fields: [fitnessPlanId], references: [id], onDelete: Cascade)
  date                 DateTime         @default(now())
  workoutName          String
  workoutType          String           @default("HOME") // HOME, GYM
  duration             Int?             // minutes
  calories             Int?
  notes                String?
  completed            Boolean          @default(true) // Legacy field, keeping for compatibility
  status               String           @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED
  completionPercentage Int              @default(0)
  records              ExerciseRecord[]
  feedback             UserFeedback?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model ExerciseRecord {
  id               String         @id @default(cuid())
  workoutSessionId String
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  exerciseName     String
  sets             Int
  reps             String         // e.g., "10, 10, 8"
  weight           String?        // e.g., "50 lbs"
  skipped          Boolean        @default(false)
  notes            String?
  createdAt        DateTime       @default(now())
}

model UserFeedback {
  id               String         @id @default(cuid())
  workoutSessionId String         @unique
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  difficulty       String         // Easy, Moderate, Hard
  energyLevel      Int            // 1-5
  sorenessLevel    Int            // 1-5
  enjoymentLevel   Int?           // 1-5
  notes            String?
  createdAt        DateTime       @default(now())
}

model BodyMeasurement {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  weight    Float?   // kg or lbs
  bodyFat   Float?   // percentage
  notes     String?
  createdAt DateTime @default(now())
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "workout" or "exercise"
  name      String
  data      Json?    // Optional data to store the favorite content
  createdAt DateTime @default(now())
}
